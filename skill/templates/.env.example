# Copy this file to .env and fill in exactly ONE backend block.
# The app picks the first configured backend in this order:
# LM Studio → Ollama → Anthropic API → Claude Code CLI → OpenRouter

# ── Option 1: LM Studio (local, free, private) ────────────────────────────
# Start LM Studio, load a model, then enable the local server.
# LMSTUDIO_URL=http://localhost:1234/v1
# LLM_MODEL=                       # leave blank to auto-detect the loaded model

# ── Option 2: Ollama (local, free, private) ────────────────────────────────
# OLLAMA_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:26b           # or gemma4:9b (16 GB RAM), gemma4:e4b (phone)

# ── Option 3: Claude via Anthropic API ────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
# LLM_MODEL=claude-sonnet-4-6      # or claude-haiku-4-5-20251001, claude-opus-4-7

# ── Option 4: Claude Code CLI (no API key — uses your Claude Code session) ─
# Requires `claude` CLI installed and authenticated (claude auth login).
# CLAUDE_CODE_CLI=1

# ── Option 5: OpenRouter (hosted, many models) ────────────────────────────
# Get a free key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY
# LLM_MODEL=google/gemma-4-26b-a4b-it   # or any OpenRouter model id
