# Secrets — NEVER commit
.env
.env.local
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# rsconnect deployment metadata (account-specific)
rsconnect-python/

# Generated graph snapshots — rebuilt at runtime
examples/*/app/www/graph-*.html

# Video build intermediates — final mp4 only
examples/*/video/audio/
examples/*/video/parts/
examples/*/video/jason_raw.*

# Build / cache
build/
dist/
*.log
