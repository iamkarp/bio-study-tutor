# Copy this file to .env. Choose ONE of the two backends below.
#
# ─────────────────────────────────────────────────────────────────────────
# OPTION A — Local Ollama (recommended for offline / private / free)
# ─────────────────────────────────────────────────────────────────────────
# 1. Install Ollama: https://ollama.com
# 2. Pull Gemma 4:
#       ollama pull gemma4:26b   (best — needs ~24 GB RAM)
#       ollama pull gemma4:9b    (lighter — needs ~10 GB RAM)
#       ollama pull gemma4:e4b   (smallest — runs on a phone)
# 3. Start the Ollama server (it usually starts automatically).
# 4. Uncomment the two lines below.

# OLLAMA_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:26b

# ─────────────────────────────────────────────────────────────────────────
# OPTION B — Hosted via OpenRouter (no local install, pay-per-token)
# ─────────────────────────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys (free tier available).

OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# Optional: override the default model. Any OpenRouter model id works.
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
